generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                 String            @id @default(cuid())
  name               String
  slug               String            @unique
  customDomain       String?           @unique
  refCode            String?           @unique
  plan               Plan              @default(FREE)
  logoUrl            String?
  themeColor         String            @default("#FF6B00")
  themeConfig        Json?
  isActive           Boolean           @default(true)
  isOpen             Boolean           @default(true)
  lineUserId         String?
  phone              String?
  bannerUrl          String?
  description        String?
  address            String?
  openTime           String            @default("09:00")
  closeTime          String            @default("21:00")
  bankName           String            @default("กสิกรไทย (KBank)")
  bankAccount        String?
  deliveryEnabled    Boolean           @default(true)
  pickupEnabled      Boolean           @default(true)
  deliveryFee        Decimal           @default(30)
  promptPayQrUrl     String?
  socialLinks        Json?
  weeklyHolidays     Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  addBefriendService Boolean           @default(false)
  trialEndsAt        DateTime?
  categories         Category[]
  helpdeskTickets    HelpdeskTicket[]
  orders             Order[]
  paymentApprovals   PaymentApproval[]
  products           Product[]
  shifts             Shift[]
  subscriptions      Subscription[]
  tables             Table[]
  users              User[]
}

model Shift {
  id         String    @id @default(cuid())
  tenantId   String
  staffId    String
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  cashIn     Decimal   @default(0)
  cashOut    Decimal?
  actualCash Decimal?
  difference Decimal?
  status     String    @default("OPEN")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Table {
  id           String   @id @default(cuid())
  number       String
  status       String   @default("vacant")
  capacity     Int      @default(4)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  currentItems Json?
  customer     String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, number])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String
  role          Role      @default(TENANT_ADMIN)
  tenantId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  posPin        String?
  accounts      Account[]
  sessions      Session[]
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, posPin])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  slug      String
  order     Int       @default(0)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, slug])
  @@unique([tenantId, name])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  imageUrl      String?
  categoryId    String
  isAvailable   Boolean  @default(true)
  isRecommended Boolean  @default(false)
  addons        Json?
  stockQuantity Int      @default(0)
  trackStock    Boolean  @default(false)
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model Order {
  id            String   @id @default(cuid())
  orderId       String   @unique
  shopSlug      String
  customer      Json
  items         Json
  totalAmount   Decimal
  status        String   @default("new")
  orderType     String   @default("pickup")
  paymentMethod String   @default("cash")
  source        String   @default("storefront")
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  riderName     String?
  tableNumber   String?
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(cuid())
  tenantId  String
  amount    Decimal
  startDate DateTime @default(now())
  endDate   DateTime
  status    String   @default("ACTIVE")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HelpdeskTicket {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  tenantId  String
  subject   String
  status    String   @default("OPEN")
  priority  String   @default("MEDIUM")
  ownerName String
  email     String
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Promotion {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String
  value       Decimal
  minPurchase Decimal?  @default(0)
  usageCount  Int       @default(0)
  usageLimit  Int?
  status      String    @default("ACTIVE")
  expiryDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PaymentApproval {
  id          String    @id @default(cuid())
  refId       String    @unique
  tenantId    String
  plan        String
  amount      Decimal
  bank        String
  status      String    @default("PENDING")
  slipUrl     String?
  reason      String?
  processedBy String?
  processedAt DateTime?
  aiAnalysis  Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?  @default("General")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MascotTicket {
  id        String   @id @default(cuid())
  shopSlug  String
  subject   String
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BroadcastMessage {
  id            String    @id @default(cuid())
  title         String
  content       String
  type          String    @default("INFO")
  author        String    @default("System Admin")
  isGlobal      Boolean   @default(true)
  targetTenants Json?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PlatformConfig {
  id           Int      @id @default(1)
  platformName String   @default("Tamjai Pro")
  supportEmail String   @default("support@tamjai.pro")
  supportPhone String   @default("02-XXX-XXXX")
  updatedAt    DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  STAFF
}

enum Plan {
  FREE
  PRO
  POS
}
