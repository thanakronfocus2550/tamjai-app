// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  STAFF
}

enum Plan {
  FREE
  PRO
}

model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  customDomain  String?   @unique
  plan          Plan      @default(FREE)
  logoUrl       String?
  themeColor    String    @default("#FF6B00")
  themeConfig   Json?     // { primaryColor: string, darkMode: boolean, etc }
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  users         User[]
  categories    Category[]
  products      Product[]
  orders        Order[]
  subscriptions Subscription[]
  helpdeskTickets HelpdeskTicket[]
  paymentApprovals PaymentApproval[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String
  role          Role      @default(TENANT_ADMIN)
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  order       Int       @default(0)
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String    @id @default(cuid())
  name          String
  description   String?
  price         Decimal
  imageUrl      String?
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  isAvailable   Boolean   @default(true)
  addons        Json?     // Array of { name: string, price: number }
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Order {
  id            String   @id @default(cuid())
  orderId       String   @unique
  shopSlug      String
  customer      Json     // { name, phone, address }
  items         Json     // Array of { name, qty, price, options }
  totalAmount   Decimal
  status        String   @default("new") // new, prepping, ready, completed, cancelled
  paymentMethod String   @default("cash")
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscription {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  amount        Decimal
  startDate     DateTime  @default(now())
  endDate       DateTime
  status        String    @default("ACTIVE")
}

model HelpdeskTicket {
  id        String   @id @default(cuid())
  ticketId  String   @unique // TK-2024-001 format
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  subject   String
  status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority  String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  ownerName String
  email     String
  messages  Json     @default("[]") // Array of { role: 'merchant'|'admin', content: string, createdAt: date }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Promotion {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   // PERCENTAGE, FIXED
  value       Decimal
  minPurchase Decimal? @default(0)
  usageCount  Int      @default(0)
  usageLimit  Int?
  status      String   @default("ACTIVE") // ACTIVE, WARNING, EXPIRED, INACTIVE
  expiryDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentApproval {
  id          String   @id @default(cuid())
  refId       String   @unique // PAY-001 format
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  plan        String
  amount      Decimal
  bank        String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  slipUrl     String?
  reason      String?  // Rejection reason
  processedBy String?  // Admin name
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?  @default("General")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// NextAuth Models

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
